<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guilherme Miguens — GitHub Contributions</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
  background:#0d1117;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  min-height:100vh;
  font-family:'Segoe UI',system-ui,sans-serif;
}
.container{
  background:#161b22;
  border:1px solid #30363d;
  border-radius:12px;
  padding:20px 24px;
  max-width:98vw;
  overflow:hidden;
}
.header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.title{color:#e6edf3;font-size:14px;font-weight:600}
.sub{color:#7d8590;font-size:12px}
.graph-wrap{overflow-x:auto;padding-bottom:4px}
canvas{display:block;image-rendering:pixelated}
.footer{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:10px;
}
.legend{display:flex;align-items:center;gap:6px;font-size:11px;color:#7d8590}
.legend-boxes{display:flex;gap:3px}
.lb{width:11px;height:11px;border-radius:2px}
.badge{
  background:#21262d;border:1px solid #30363d;
  border-radius:6px;padding:4px 10px;
  font-size:11px;color:#7d8590;
  display:flex;align-items:center;gap:6px;
}
.badge span{color:#3fb950;font-weight:600}
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div>
      <div class="title">guilhermedeoliveiramiguens</div>
      <div class="sub" id="contrib-count">carregando contribuições...</div>
    </div>
    <div class="badge">Score: <span id="score">0</span></div>
  </div>
  <div class="graph-wrap">
    <canvas id="c"></canvas>
  </div>
  <div class="footer">
    <div class="legend">
      Menos
      <div class="legend-boxes">
        <div class="lb" style="background:#161b22;border:1px solid #30363d"></div>
        <div class="lb" style="background:#0e4429"></div>
        <div class="lb" style="background:#006d32"></div>
        <div class="lb" style="background:#26a641"></div>
        <div class="lb" style="background:#39d353"></div>
      </div>
      Mais
    </div>
    <div class="legend" style="gap:10px">
      <span>←→ mover</span>
      <span>SPACE pausar</span>
    </div>
  </div>
</div>

<script>
const cv = document.getElementById('c');
const ctx = cv.getContext('2d');

const CELL = 13;
const GAP = 2;
const STEP = CELL + GAP;
const COLS = 53;
const ROWS = 7;
const W = COLS * STEP + 2;
const H = ROWS * STEP + 30;

cv.width = W;
cv.height = H;

const MONTHS = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
const COLORS = ['#161b22','#0e4429','#006d32','#26a641','#39d353'];
const BORDER = ['#30363d','#033a16','#005924','#1f8535','#2ea043'];

// Generate contribution grid
function seededRand(seed){
  let s=seed;
  return ()=>{s=(s*9301+49297)%233280;return s/233280;};
}
const rand = seededRand(42);

let grid = [];
let totalContribs = 0;
for(let c=0;c<COLS;c++){
  grid[c]=[];
  for(let r=0;r<ROWS;r++){
    let v=0;
    const rnd=rand();
    if(rnd>0.55){
      v=Math.floor(rand()*4)+1;
      totalContribs+=v*3;
    }
    // Make some clusters
    if(c>30&&c<45&&r>1&&r<6&&rand()>0.3) v=Math.floor(rand()*4)+1;
    grid[c][r]=Math.min(4,v);
  }
}
grid[0][0]=0;grid[0][1]=0;grid[0][2]=0;

document.getElementById('contrib-count').textContent=totalContribs+' contribuições no último ano';

// ── PACMAN STATE ──
let pac = {
  col: 0,
  row: 3,
  x: 0,
  y: 0,
  dir: 1,       // 1=right, -1=left
  mouthAngle: 0,
  mouthDir: 1,
  speed: 0.04,  // cols per frame
  t: 0,         // fractional col position
  eating: false,
  score: 0,
};

// Path: pac-man follows a snake path through the grid
// Build a path of (col, row) waypoints
function buildPath(){
  const path=[];
  // zigzag: go right across all cols, alternate rows
  // Simplified: go right on row 0, drop, go right on row 1, etc
  // Actually do a proper snake: alternate direction each row
  for(let r=0;r<ROWS;r++){
    if(r%2===0){
      for(let c=0;c<COLS;c++) path.push({c,r});
    } else {
      for(let c=COLS-1;c>=0;c--) path.push({c,r});
    }
  }
  return path;
}

const PATH = buildPath();
let pathIdx = 0;
let subT = 0; // 0..1 between path[pathIdx] and path[pathIdx+1]

// Ghosts
const GHOST_COLORS=['#ff0000','#ffb8ff','#00ffff','#ffb852'];
let ghosts = GHOST_COLORS.map((color,i)=>({
  col: Math.floor(COLS*0.2)+i*8,
  row: Math.floor(Math.random()*ROWS),
  color,
  dir: i%2===0?1:-1,
  t: 0,
  speed: 0.015+i*0.003,
  wobble: i*0.8,
}));

// Eaten cells (pac-man eats green cells)
let eaten = Array.from({length:COLS},()=>Array(ROWS).fill(false));
let paused = false;
let frame = 0;

// Draw month labels
function drawMonths(){
  ctx.font='10px system-ui';
  ctx.fillStyle='#7d8590';
  ctx.textAlign='left';
  const now = new Date();
  const startMonth = (now.getMonth()+1)%12;
  for(let i=0;i<12;i++){
    const mIdx=(startMonth+i)%12;
    const col=Math.floor(i*(COLS/12));
    ctx.fillText(MONTHS[mIdx], col*STEP+1, 10);
  }
}

function cellX(col){return col*STEP}
function cellY(row){return row*STEP+18}

function drawGrid(){
  for(let c=0;c<COLS;c++){
    for(let r=0;r<ROWS;r++){
      const v = eaten[c][r] ? 0 : grid[c][r];
      ctx.fillStyle = COLORS[v];
      ctx.strokeStyle = BORDER[v];
      ctx.lineWidth=0.5;
      roundRect(ctx, cellX(c)+1, cellY(r)+1, CELL-1, CELL-1, 2);
      ctx.fill();
      ctx.stroke();
    }
  }
}

function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);
  ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
  ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);
  ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);
  ctx.closePath();
}

function drawPacman(){
  const cx = cellX(pac.col) + STEP/2 + Math.cos(pac.mouthAngle*0.3)*1;
  const cy = cellY(pac.row) + STEP/2;
  const r = CELL*0.52;

  pac.mouthAngle += 0.18*pac.mouthDir;
  if(pac.mouthAngle>0.9||pac.mouthAngle<0.05) pac.mouthDir*=-1;

  const mouth = pac.mouthAngle * 0.4;
  const startA = pac.dir>0 ? mouth : Math.PI+mouth;
  const endA   = pac.dir>0 ? Math.PI*2-mouth : Math.PI*3-mouth;

  ctx.fillStyle='#FFD700';
  ctx.beginPath();
  ctx.moveTo(cx,cy);
  ctx.arc(cx,cy,r,startA,endA);
  ctx.closePath();
  ctx.fill();

  // Eye
  const eyeX = cx + (pac.dir>0?2:-2);
  const eyeY = cy - r*0.4;
  ctx.fillStyle='#0d1117';
  ctx.beginPath();
  ctx.arc(eyeX,eyeY,1.5,0,Math.PI*2);
  ctx.fill();
}

function drawGhost(g){
  const cx = cellX(g.col) + STEP/2;
  const cy = cellY(g.row) + STEP/2;
  const w2 = CELL*0.5;
  const h2 = CELL*0.56;

  // Body
  ctx.fillStyle = g.color;
  ctx.beginPath();
  ctx.arc(cx, cy-h2*0.1, w2, Math.PI, 0);
  ctx.lineTo(cx+w2, cy+h2*0.8);
  // Wavy bottom
  const segs=3;
  for(let i=segs;i>=0;i--){
    const bx=cx-w2+w2*2*(i/segs);
    const by=cy+h2*0.8-(i%2===0?0:h2*0.25);
    ctx.lineTo(bx,by);
  }
  ctx.closePath();
  ctx.fill();

  // Eyes
  const eyeOff=w2*0.3;
  [[-1,1]].forEach(()=>{
    ctx.fillStyle='#fff';
    ctx.beginPath();ctx.ellipse(cx-eyeOff,cy-h2*0.1,w2*0.28,h2*0.28,0,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.ellipse(cx+eyeOff,cy-h2*0.1,w2*0.28,h2*0.28,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#00f';
    ctx.beginPath();ctx.ellipse(cx-eyeOff+1,cy-h2*0.05,w2*0.14,h2*0.16,0,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.ellipse(cx+eyeOff+1,cy-h2*0.05,w2*0.14,h2*0.16,0,0,Math.PI*2);ctx.fill();
  });

  // Wobble animation
  g.wobble+=0.08;
}

function updatePacman(){
  if(paused)return;

  subT += pac.speed;
  if(subT>=1){
    subT=0;
    // Eat cell at current position
    const cur=PATH[pathIdx];
    if(grid[cur.c][cur.r]>0&&!eaten[cur.c][cur.r]){
      eaten[cur.c][cur.r]=true;
      pac.score+=grid[cur.c][cur.r]*10;
      document.getElementById('score').textContent=pac.score;
    }
    pathIdx=(pathIdx+1)%PATH.length;
    if(pathIdx===0) eaten=Array.from({length:COLS},()=>Array(ROWS).fill(false));
  }

  // Interpolate between path positions
  const cur=PATH[pathIdx];
  const next=PATH[(pathIdx+1)%PATH.length];
  pac.col=cur.c+(next.c-cur.c)*subT;
  pac.row=cur.r+(next.r-cur.r)*subT;
  pac.dir=next.c>=cur.c?1:-1;
}

function updateGhosts(){
  ghosts.forEach(g=>{
    g.t+=g.speed;
    if(g.t>=1){
      g.t=0;
      g.col+=g.dir;
      if(g.col>=COLS-1||g.col<=0){
        g.dir*=-1;
        g.row=(g.row+1)%ROWS;
      }
    }
    // Smooth position (just integer for ghosts)
  });
}

// Dots on path (pellets)
function drawPellets(){
  PATH.forEach((p,i)=>{
    if(!eaten[p.c]||!eaten[p.c][p.r]){
      if(grid[p.c][p.r]>0&&!eaten[p.c][p.r]){
        const cx=cellX(p.c)+STEP/2;
        const cy=cellY(p.row||p.r)+STEP/2;
        ctx.fillStyle='rgba(255,255,255,0.25)';
        ctx.beginPath();
        ctx.arc(cx,cy,1.5,0,Math.PI*2);
        ctx.fill();
      }
    }
  });
}

function draw(){
  ctx.clearRect(0,0,W,H);
  drawMonths();
  drawGrid();
  drawPellets();
  ghosts.forEach(drawGhost);
  drawPacman();
  frame++;
}

function loop(){
  updatePacman();
  updateGhosts();
  draw();
  requestAnimationFrame(loop);
}

// Controls
document.addEventListener('keydown',e=>{
  if(e.key===' '){paused=!paused;e.preventDefault();}
  if(e.key==='ArrowRight') pac.speed=Math.min(0.12,pac.speed+0.01);
  if(e.key==='ArrowLeft')  pac.speed=Math.max(0.01,pac.speed-0.01);
});

loop();
</script>
</body>
</html>
